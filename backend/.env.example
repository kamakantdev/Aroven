# Environment Variables for Swastik Healthcare Backend

# Server Configuration
NODE_ENV=development
PORT=5001

# Supabase Configuration (Authentication & Database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-chars
JWT_ACCESS_SECRET=your-access-token-secret-optional
JWT_REFRESH_SECRET=your-refresh-token-secret-optional
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# AI service URL
AI_SERVICE_URL=http://localhost:8000

# MinIO Configuration (File Storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=swastik-healthcare

# OpenAI Configuration (for Medical Chatbot)
OPENAI_API_KEY=your-openai-api-key

# Redis Configuration
# Option A: Upstash REST (preferred for serverless)
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Option B: Standard Redis URL (used by AI service and backend fallback)
REDIS_URL=redis://localhost:6379

# Email Configuration (Gmail SMTP via Nodemailer)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
EMAIL_FROM_NAME=Swastik Healthcare
EMAIL_FROM_ADDRESS=noreply@swastik.health
FROM_EMAIL=noreply@swastik.com

# Firebase Admin Configuration (for Push Notifications via FCM)
# Required by notificationService.js:
# Provide absolute path to your Firebase service-account JSON file.
FIREBASE_SERVICE_ACCOUNT=/absolute/path/to/firebase-service-account.json

# Optional legacy Firebase fields (kept for compatibility with old setups)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# Reminder/Notification Scheduler
# Runs once per minute in server.js to send medicine + appointment reminders.
# Keep enabled in normal environments.
REMINDER_CRON_ENABLED=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Frontend URLs (for CORS)
FRONTEND_WEB_URL=http://localhost:3000
FRONTEND_APP_URL=exp://localhost:8081

# Ambulance Tracking Configuration
AMBULANCE_LOCATION_UPDATE_INTERVAL=5000
MAX_AMBULANCE_SEARCH_RADIUS_KM=50
